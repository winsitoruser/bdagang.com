# ===========================================
# NainERP Backend - Environment Configuration
# ===========================================

# Server
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# Database (PostgreSQL)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=nainerp_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-token-secret
JWT_REFRESH_EXPIRES_IN=30d

# Redis (for caching & sessions)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@nainerp.com

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
LOG_DIR=./logs

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Encryption
ENCRYPTION_KEY=your-32-char-encryption-key-here

# Payment Gateway (Midtrans)
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# WhatsApp Business API
WA_API_URL=
WA_API_TOKEN=
WA_PHONE_NUMBER_ID=

# Marketplace Integration
TOKOPEDIA_APP_ID=
TOKOPEDIA_CLIENT_SECRET=
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
